#!/bin/sh

read_post() {
	len="${CONTENT_LENGTH:-0}"
	[ "$len" -gt 0 ] 2>/dev/null || return 0
	dd bs=1 count="$len" 2>/dev/null
}

urldecode() {
	v="$(sed 's/+/ /g; s/%/\\x/g')"
	printf '%b' "$v"
}

field() {
	key="$1"
	tr '&' '\n' | awk -F= -v k="$key" '$1 == k { print $2; exit }' | urldecode
}

html_escape() {
	sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g'
}

format_duration() {
	total="${1:-0}"
	[ "$total" -gt 0 ] 2>/dev/null || total=0
	days=$((total / 1440))
	rem=$((total % 1440))
	hours=$((rem / 60))
	mins=$((rem % 60))
	out=""
	[ "$days" -gt 0 ] && out="${out}${days} hari "
	[ "$hours" -gt 0 ] && out="${out}${hours} jam "
	[ "$mins" -gt 0 ] && out="${out}${mins} menit"
	[ -n "$out" ] || out="0 menit"
	echo "$out ($total menit)"
}

msg=""
ok=""

if [ "$REQUEST_METHOD" = "GET" ] && [ -n "$QUERY_STRING" ]; then
	code="$(printf '%s' "$QUERY_STRING" | field code)"
	result="$(/usr/sbin/voucherctl login "$code" 2>&1)"
	case "$result" in
		OK\|*)
			mins="${result#OK|}"
			ok="Voucher aktif selama $(format_duration "$mins"). Silakan buka ulang website tujuan."
			;;
		*) msg="$result" ;;
	esac
elif [ "$REQUEST_METHOD" = "POST" ]; then
	post="$(read_post)"
	code="$(printf '%s' "$post" | field code)"
	result="$(/usr/sbin/voucherctl login "$code" 2>&1)"
	case "$result" in
		OK\|*)
			mins="${result#OK|}"
			ok="Voucher aktif selama $(format_duration "$mins"). Silakan buka ulang website tujuan."
			;;
		*) msg="$result" ;;
	esac
fi

cat <<'EOF'
Content-Type: text/html; charset=utf-8
Cache-Control: no-store

<!doctype html>
<html lang="id">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Voucher WiFi</title>
<style>
body{margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f5f7fb;color:#111827;display:grid;min-height:100vh;place-items:center}
main{width:min(420px,calc(100% - 32px));background:white;border:1px solid #d9e0ea;border-radius:8px;padding:24px;box-shadow:0 10px 24px rgba(15,23,42,.08)}
h1{font-size:24px;margin:0 0 8px}
p{color:#4b5563;line-height:1.45}
label{display:block;font-size:13px;font-weight:700;margin:18px 0 8px}
input{box-sizing:border-box;width:100%;font-size:20px;letter-spacing:2px;text-transform:uppercase;padding:13px 14px;border:1px solid #aeb8c7;border-radius:6px}
button{width:100%;margin-top:14px;padding:13px 14px;border:0;border-radius:6px;background:#0f766e;color:white;font-weight:800;font-size:16px}
.err{background:#fff1f2;border:1px solid #fecdd3;color:#9f1239;padding:10px 12px;border-radius:6px}
.ok{background:#ecfdf5;border:1px solid #a7f3d0;color:#065f46;padding:10px 12px;border-radius:6px}
</style>
</head>
<body>
<main>
<h1>Voucher WiFi Kayla</h1>
<p>Masukkan kode voucher untuk mengaktifkan akses internet perangkat ini.</p>
<p>Untuk mendapatkan voucher, hubungi Pak Agus Kav Bambu 1 No A5.</p>
EOF

if [ -n "$msg" ]; then
	printf '<div class="err">%s</div>\n' "$(printf '%s' "$msg" | html_escape)"
fi
if [ -n "$ok" ]; then
	printf '<div class="ok">%s</div>\n' "$(printf '%s' "$ok" | html_escape)"
fi

cat <<'EOF'
<form method="get" action="/cgi-bin/voucher">
<label for="code">Kode voucher</label>
<input id="code" name="code" autocomplete="one-time-code" autofocus required>
<button type="submit">Masuk</button>
</form>
</main>
</body>
</html>
EOF
